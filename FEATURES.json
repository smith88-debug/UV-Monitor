      "critical_files": [
        "UVMonitor/Views/LocationPickerView.swift",
        "UVMonitor/Models/UVStation.swift"
      ],
      "api_endpoints": []
    },
    {
      "id": "notifications",
      "name": "UV Notifications",
      "route": null,
      "sidebar_label": null,
      "description": "Local push notifications for rising and high UV conditions based on forecast data.",
      "critical_files": [
        "UVMonitor/Notifications/UVNotificationManager.swift",
        "UVMonitor/Models/UVForecast.swift"
      ],
      "api_endpoints": []
    },
    {
      "id": "data-persistence",
      "name": "Reading Storage",
      "route": null,
      "sidebar_label": null,
      "description": "SwiftData persistence of UV readings and forecast snapshots with 30-day retention.",
