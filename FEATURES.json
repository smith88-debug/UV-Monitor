{
  "version": 1,
  "description": "Feature manifest for UV Monitor iOS app. See CLAUDE.md for rules on preserving features.",
  "shared_files": [
    "UVMonitor/Services/UVDataManager.swift",
    "UVMonitor/Models/UVStation.swift",
    "UVMonitor/Models/UVLevel.swift",
    "UVMonitor/App/UVMonitorApp.swift"
  ],
  "features": [
    {
      "id": "dashboard",
