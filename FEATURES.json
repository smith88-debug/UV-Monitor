      "critical_files": [
        "UVMonitor/Views/DashboardView.swift",
        "UVMonitor/Views/ContentView.swift",
        "UVMonitor/Views/Components/UVIndexCard.swift",
        "UVMonitor/Views/Components/ProtectionBanner.swift",
        "UVMonitor/Services/UVDataManager.swift",
        "UVMonitor/Models/UVLevel.swift"
      ],
      "api_endpoints": [
        "https://uvdata.arpansa.gov.au/xml/uvvalues.xml"
      ]
    },
    {
      "id": "forecast-chart",
      "name": "UV Forecast Chart",
      "route": null,
      "sidebar_label": null,
      "description": "Combined chart showing predicted (Open-Meteo) and measured (ARPANSA) UV data with risk zone bands.",
      "critical_files": [
        "UVMonitor/Views/UVChartView.swift",
        "UVMonitor/Models/UVForecast.swift",
        "UVMonitor/Services/OpenMeteoService.swift",
        "UVMonitor/Services/ARPANSAService.swift"
      ],
      "api_endpoints": [
